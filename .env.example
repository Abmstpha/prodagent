# LLM provider (mistral | openai | anthropic | mock — mock needs no key)
LLM_PROVIDER=mistral
MISTRAL_API_KEY=

# Web search tool (optional — web_search is disabled without it)
TAVILY_API_KEY=

# API key protecting the /mcp endpoint of the deployed backend (any random string)
MCP_API_KEY=

# Comma-separated origins allowed to call the API (default *)
CORS_ORIGINS=*

# Vector DB dense leg (optional — falls back to local TF-IDF without it)
PINECONE_API_KEY=

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
